PORT=4000
AGENT_NAME=Arissa
FOUNDER_NAME=Didi Lolade
FOUNDER_BIO=Didi Lolade a créé Arissa pour permettre à chaque entrepreneur de posséder son propre jumeau numérique et ses agents IA autonomes.

# Option A — Clé Anthropic directe (https://console.anthropic.com)
# Format : sk-ant-api03-...
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# Active l'outil de recherche web côté Anthropic (coût additionnel, désactivé par défaut)
ENABLE_WEB_SEARCH=false

# Option B — OpenRouter (alternative à Anthropic, accès multi-modèles)
# Obtenez une clé sur https://openrouter.ai/keys (format : sk-or-v1-...)
# Si OPENROUTER_API_KEY est renseigné, il prend le dessus sur ANTHROPIC_API_KEY
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# Outil send_email : créez un compte sur https://resend.com, récupérez une clé API
# et un domaine d'envoi vérifié (ou utilisez onboarding@resend.dev pour tester)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Outil send_whatsapp : créez une app sur https://developers.facebook.com, ajoutez
# le produit "WhatsApp", récupérez un numéro de test + token d'accès
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Authentification multi-utilisateurs : générez une clé de compte de service sur
# https://console.firebase.google.com (Paramètres du projet > Comptes de service
# > Générer une nouvelle clé privée), enregistrez le fichier JSON et indiquez son
# chemin ici
FIREBASE_SERVICE_ACCOUNT_PATH=
